    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.18",
    "playwright": "^1.60.0",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.3",
